# ===== Hermes WeChat Sidecar config =====
# Copy this file to `.env` and fill in real values.

# Linux adapter HTTP base URL.
# When using SSH tunnel: ssh -L 8787:127.0.0.1:8787 user@linux-host
ADAPTER_BASE_URL=http://127.0.0.1:8787

# WebSocket endpoint. device_id and token are passed as query string.
ADAPTER_WS_URL=ws://127.0.0.1:8787/ws?device_id=windows-main&token=REPLACE_ME

# Auth token, must match Linux /root/hermes-wechat-adapter/.env -> ADAPTER_AUTH_TOKEN
ADAPTER_AUTH_TOKEN=REPLACE_ME

# Local identity reported to the adapter.
DEVICE_ID=windows-main

# Comma-separated list of WeChat chats (display names) to actively listen on.
# 文件传输助手 = "File Transfer", a safe sandbox to test /ping.
LISTEN_CHATS=文件传输助手

# Group messages: only forward when message starts with one of these prefixes
# OR @-mentions the logged-in user. Comma-separated, empty disables prefix mode.
GROUP_PREFIXES=/

# Heartbeat / reconnect tuning (seconds).
HEARTBEAT_INTERVAL=20
RECONNECT_MIN=1
RECONNECT_MAX=30

# Where to save files downloaded from Linux before forwarding to WeChat.
DOWNLOAD_DIR=C:\HermesWeChatSidecar\data\downloads

# Where wxauto should drop incoming media (created automatically).
INBOUND_MEDIA_DIR=C:\HermesWeChatSidecar\data\inbound

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
